{
  "name": "git-personas",
  "version": "1.0.0",
  "description": "Terminal UI for managing git personas",
  "main": "dist/cli.js",
  "bin": {
    "git-personas": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc",
    "start": "node dist/cli.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "ink": "^5.2.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.30.0",
    "simple-git-hooks": "^2.13.1",
    "typescript-eslint": "^8.60.1"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check"
  }
}
